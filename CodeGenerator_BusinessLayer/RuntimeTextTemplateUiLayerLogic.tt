<#+


List <string> GetListInputOfControlsNotAllowNull()
{
    List<string> ListInputOfControlsNotAllowNull = new List<string>();

    enControls ControlName = enControls.None;

    for (short i = 0; i < ListOfColunmData.Count; i++)
    {
        Enum.TryParse(ListOfColunmData[i].ControlName, out ControlName);

        if (ListOfColunmData[i].Generate && !ListOfColunmData[i].IsNullable && (ControlName == enControls.TextBox || ControlName == enControls.MaskedTextBox || ControlName == enControls.ComboBox))
        {
            ListInputOfControlsNotAllowNull.Add($"!string.IsNullOrWhiteSpace({RuntimeTextTemplateUiLayerDesigner.GetControlName(ControlName, ListOfColunmData[i].NameWithout_)}.Text)");
        }
    }

    return ListInputOfControlsNotAllowNull;
}

public string NameSpace { get; set; } = "";

string _TableSingleName = "";
public string TableSingleName
{
    get
    {
        return _TableSingleName;
    }
    set
    {
        _TableSingleName = value;

        _TableSingleName = _TableSingleName?.Replace("_", "");
    }
}

string _TableName = "";
public string TableName
{
    get 
    {    
        return _TableName;
    }
    set
    {
        _TableName = value;

        _TableName = _TableName?.Replace("_", "");
    }
}

public bool IsInput { get; set; }
public bool IsView { get; set; }

// لو هذا المتغير بيساوي false معناها ان هيتم انشاء user control
public bool IsForm { get; set; }

private List<string> ListInputOfControlsNotAllowNull = new List<string>();

private List<clsColumnDataUILayer> _ListOfColunmData {  get; set; }
public List<clsColumnDataUILayer> ListOfColunmData 
{
     get
     {
          if (_ListOfColunmData == null)
          {
               return new List<clsColumnDataUILayer>();
          }
          else
          {
               return _ListOfColunmData;
          }
     }
     set
     {
          _ListOfColunmData = value;

          if (_ListOfColunmData != null)
          {
                ListInputOfControlsNotAllowNull = GetListInputOfControlsNotAllowNull();
          }
     }
}

#>