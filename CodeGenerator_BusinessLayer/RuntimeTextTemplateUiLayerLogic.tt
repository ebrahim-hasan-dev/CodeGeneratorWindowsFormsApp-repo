<# if (IsInput) { #>
        void ShowMissingMessage()
        {
            MessageBox.Show("One of the requirements is missing", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
        }

        void btSave_Click(object sender, EventArgs e)
        {
            if (!this.ValidateChildren())
            {
                ShowMissingMessage();
                return;
            }

            if (
<# for (short i = 0; i < ListInputOfControlsNotAllowNull.Count; i++) { #>
                <#= ListInputOfControlsNotAllowNull[i] #><#= (i < ListInputOfControlsNotAllowNull.Count - 1) ? " &&" : "" #>
<# } #>
               )
            {
                
            }
            else
            {
                ShowMissingMessage();
            }
        }

<# if (ListInputOfControlsNotAllowNull.Count > 0) { #>
        void InputControls_ValidatingHelper(MaskedTextBox maskedtextBox, CancelEventArgs e)
        {
            if (maskedtextBox != null)
            {
                if (string.IsNullOrWhiteSpace(maskedtextBox.Text))
                {
                    errorProvider1.SetError(maskedtextBox, "This box should not be empty!");
                    e.Cancel = true;
                }
                else if (!maskedtextBox.MaskCompleted)
                {
                    errorProvider1.SetError(maskedtextBox, "The requirements for this box are not complete!");
                    e.Cancel = true;
                }
                else
                {
                    errorProvider1.SetError(maskedtextBox, "");
                    e.Cancel = false;
                }
            }
        }

        void InputControls_ValidatingHelper(TextBox textBox, CancelEventArgs e)
        {
            if (textBox != null)
            {
                if (string.IsNullOrWhiteSpace(textBox.Text))
                {
                    errorProvider1.SetError(textBox, "This box should not be empty!");
                    e.Cancel = true;
                }
                else
                {
                    errorProvider1.SetError(textBox, "");
                    e.Cancel = false;
                }
            }
        }

        void InputControls_ValidatingHelper(ComboBox comboBox, CancelEventArgs e)
        {
            if (comboBox != null)
            {
                if (string.IsNullOrWhiteSpace(comboBox.Text))
                {
                    errorProvider1.SetError(comboBox, "This box should not be empty!");
                    e.Cancel = true;
                }
                else
                {
                    errorProvider1.SetError(comboBox, "");
                    e.Cancel = false;
                }
            }
        }

        void InputControls_Validating(object sender, CancelEventArgs e)
        {
            if (sender is TextBox)
            {
                TextBox textBox = sender as TextBox;

                InputControls_ValidatingHelper(textBox, e);
            }
            else if (sender is MaskedTextBox)
            {
                MaskedTextBox maskedtextBox = sender as MaskedTextBox;

                InputControls_ValidatingHelper(maskedtextBox, e);
            }
            else if (sender is ComboBox)
            {
                ComboBox comboBox = sender as ComboBox;

                InputControls_ValidatingHelper(comboBox, e);
            }
        }
<# } #>
<# } #>
