                lbNumberOfRowsResult.Text = ListOf<#= TableName #>.Count.ToString();

                dgv<#= TableName #>.Rows.Clear();

                for (int i = 0; i < ListOf<#= TableName #>.Count; i++)
                {
                    dgv<#= TableName #>.Rows.Add(new object[] {
<# for (short i = 0; i < ListOfColunmData.Count; i++) { #>
                     ListOf<#= TableName #>[i].<#= ListOfColunmData[i].NameWithout_ #><#= (i == ListOfColunmData.Count - 1) ? "" : "," #>
<# } #>
                         });
                }
            }
        }

