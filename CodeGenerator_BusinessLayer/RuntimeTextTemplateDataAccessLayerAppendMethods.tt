            if (<#= HandleCorrectCheckParamerter(ExistParameterName).Replace("_", "") #>)
            {
                SqlConnection Connection = null;
                SqlCommand Command = null;
                SqlDataReader Reader = null;

                try
                {
                    Connection = new SqlConnection(clsConnectionString.ConnectionString);

                    string FindQuery = "select [<#= ExistParameterName #>] from [<#= TableName #>] where [<#= ExistParameterName #>] = @<#= ExistParameterName.Replace("_", "") #>;";

                    Command = new SqlCommand(FindQuery, Connection);

                    Command.Parameters.AddWithValue("@<#= ExistParameterName.Replace("_", "") #>", <#= ExistParameterName.Replace("_", "") #>);

                    Connection.Open();

                    Reader = Command.ExecuteReader();

                    if (Reader.HasRows)
                    {
                        Exist = true;
                    }
                }
                finally
                {
                    if (Reader != null)
                    {
                        Reader.Close();
                        Reader.Dispose();
                    }

                    if (Command != null)
                    {
                        Command.Dispose();
                    }

                    if (Connection != null)
                    {
                        Connection.Close();
                        Connection.Dispose();
                    }
                }
            }

            return Exist;
