<# } #>
<# if (!Columns[i].IsNullable) { #>
                    Command.Parameters.AddWithValue("@<#= Columns[i].NameWithout_ #>", <#= TableSingleName #>.<#= Columns[i].NameWithout_ #>);
<# } #>
<# } #>

