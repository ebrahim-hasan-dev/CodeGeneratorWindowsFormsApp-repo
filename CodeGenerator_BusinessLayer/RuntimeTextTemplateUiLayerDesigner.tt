                    }
            break;
        case enControls.CheckBox:
            Value =
                $"//\n" +
                $"\t\t\t// chb{ColumnName}\n" +
                $"\t\t\t//\n" +
                $"\t\t\tthis.chb{ColumnName}.AutoSize = true;\n" +
                $"\t\t\tthis.chb{ColumnName}.Location = new System.Drawing.Point({point.X}, {point.Y});\n" +
