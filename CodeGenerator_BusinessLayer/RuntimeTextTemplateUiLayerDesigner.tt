void CaseSameColumnNameAndSameControlNameHandle(string ColumnName)
{
    if (ListOfColunmData != null)
    {
        byte Count = (byte)ListOfColunmData.Count(x => x.Name == ColumnName);

        if (Count > 1)
        {
            short Index = (short)ListOfColunmData.FindLastIndex(x => x.Name == ColumnName);

            ListOfColunmData[Index].Name = ListOfColunmData[Index].Name + 2;
        }
    }
}

List<string> GetListOfInitializedProperties()
{
    List<string> ListOfInitializedProperties = new List<string>();

    enControls ControlName = enControls.None;

    Point LabelPoint = new Point(0, 10);
    Point ControlPoint = new Point(210, 10);

    for (short i = 0; i < ListOfColunmData.Count; i++)
    {
        if (ListOfColunmData[i].Generate)
        {
            Enum.TryParse(ListOfColunmData[i].ControlName, out ControlName);

            if (ControlName != enControls.CheckBox)
            {
                ListOfInitializedProperties.Add(GetInitializedProperties(enControls.Label, ListOfColunmData[i].Name, i, ListOfColunmData[i].IsNullable, LabelPoint, true));
                
                ListOfInitializedProperties.Add(GetInitializedProperties(ControlName, ListOfColunmData[i].Name, i, ListOfColunmData[i].IsNullable, ControlPoint));
            }
            else
            {
                ListOfInitializedProperties.Add(GetInitializedProperties(ControlName, ListOfColunmData[i].Name, i, ListOfColunmData[i].IsNullable, ControlPoint));
            }

            if (ControlPoint.Y >= 425)
            {
                ControlPoint.Y = 10;
                ControlPoint.X += 440;

                LabelPoint.Y = 10;
                LabelPoint.X += 440;
            }
            else
            {
                ControlPoint.Y += 35;
                LabelPoint.Y += 35;
            }
        }
    }

    return ListOfInitializedProperties;
}

public static string GetControlName(enControls ControlName, string ColumnName, bool IsLabel = false)
        {
            switch (ControlName)
            {
                case enControls.Label:
                    if (!IsLabel)
                    {
                        return $"lb{ColumnName}Result";
                    }
                    else
                    {
                        return $"lb{ColumnName}";
                    }
                case enControls.CheckBox:
                    return $"chb{ColumnName}";
                case enControls.TextBox:
                    return $"txtb{ColumnName}";
                case enControls.MaskedTextBox:
                    return $"mtxtb{ColumnName}";
                case enControls.DateTimePicker:
                    return $"dtp{ColumnName}";
                case enControls.ComboBox:
                    return $"cb{ColumnName}";
                default:
                    return $"lb{ColumnName}";
            }
        }

        List<string> GetListOfControlNames()
        {
            List<string> ListOfControlNames = new List<string>();

            enControls ControlName = enControls.None;

            for (short i = 0; i < ListOfColunmData.Count; i++)
            {
                if (ListOfColunmData[i].Generate)
                {
                    Enum.TryParse(ListOfColunmData[i].ControlName, out ControlName);

                    if (ControlName != enControls.CheckBox)
                    {
                        ListOfControlNames.Add(GetControlName(enControls.Label, ListOfColunmData[i].NameWithout_, true));
                    }

                    ListOfControlNames.Add(GetControlName(ControlName, ListOfColunmData[i].NameWithout_));
                }
            }

            return ListOfControlNames;
        }


string GetControlInitialized(enControls ControlName, string ColumnName, bool IsLabel = false)
{
     switch (ControlName)
     {
          case enControls.Label:
               if (!IsLabel)
               {
                   return $"this.lb{ColumnName}Result = new System.Windows.Forms.{enControls.Label.ToString()}();";
               }
               else
               {
                   return $"this.lb{ColumnName} = new System.Windows.Forms.{enControls.Label.ToString()}();";
               }
          case enControls.CheckBox:
              return $"this.chb{ColumnName} = new System.Windows.Forms.{enControls.CheckBox.ToString()}();";
          case enControls.TextBox:
              return $"this.txtb{ColumnName} = new System.Windows.Forms.{enControls.TextBox.ToString()}();";
          case enControls.MaskedTextBox:
              return $"this.mtxtb{ColumnName} = new System.Windows.Forms.{enControls.MaskedTextBox.ToString()}();";
          case enControls.DateTimePicker:
              return $"this.dtp{ColumnName} = new System.Windows.Forms.{enControls.DateTimePicker.ToString()}();";
          case enControls.ComboBox:
              return $"this.cb{ColumnName} = new System.Windows.Forms.{enControls.ComboBox.ToString()}();";
          default:
              return $"this.lb{ColumnName} = new System.Windows.Forms.{enControls.Label.ToString()}();";
     }
}

List<string> GetListOfInitializedControls()
{
     List<string> ListOfInitializedControls = new List<string>();

     enControls ControlName = enControls.None;

     for (short i = 0; i < ListOfColunmData.Count; i++)
     {
         if (ListOfColunmData[i].Generate)
         {
              CaseSameColumnNameAndSameControlNameHandle(ListOfColunmData[i].Name);
                
              Enum.TryParse(ListOfColunmData[i].ControlName, out ControlName);

              if (ControlName != enControls.CheckBox)
              {
                  ListOfInitializedControls.Add(GetControlInitialized(enControls.Label, ListOfColunmData[i].NameWithout_, true));
              }

              ListOfInitializedControls.Add(GetControlInitialized(ControlName, ListOfColunmData[i].NameWithout_));
         }
     }

     return ListOfInitializedControls;
}

string GetCreatedObjectsOfControl(enControls ControlName, string ColumnName, bool IsLabel = false)
{  
      switch (ControlName)
      {
           case enControls.Label:
               if (!IsLabel)
               {
                   return $"private System.Windows.Forms.{ControlName.ToString()} lb{ColumnName}Result;";
               }
               else
               {
                   return $"private System.Windows.Forms.{ControlName.ToString()} lb{ColumnName};";
               }
           case enControls.CheckBox:
               return $"private System.Windows.Forms.{ControlName.ToString()} chb{ColumnName};";
           case enControls.TextBox:
               return $"private System.Windows.Forms.{ControlName.ToString()} txtb{ColumnName};";
           case enControls.MaskedTextBox:
               return $"private System.Windows.Forms.{ControlName.ToString()} mtxtb{ColumnName};";
           case enControls.DateTimePicker:
               return $"private System.Windows.Forms.{ControlName.ToString()} dtp{ColumnName};";
           case enControls.ComboBox:
               return $"private System.Windows.Forms.{ControlName.ToString()} cb{ColumnName};";
           default:
               return $"private System.Windows.Forms.{ControlName.ToString()} lb{ColumnName};";
      }
}

 List<string> GetListOfCreatedObjectsOfControls()
{
     List<string> ListOfCreatedObjectsOfControls = new List<string>();

     enControls ControlName = enControls.None;

      for (short i = 0; i < ListOfColunmData.Count; i++)
      {
           if (ListOfColunmData[i].Generate)
           {
                Enum.TryParse(ListOfColunmData[i].ControlName, out ControlName);

                if (ControlName != enControls.CheckBox)
                {
                    ListOfCreatedObjectsOfControls.Add(GetCreatedObjectsOfControl(enControls.Label, ListOfColunmData[i].NameWithout_, true));
                }

                ListOfCreatedObjectsOfControls.Add(GetCreatedObjectsOfControl(ControlName, ListOfColunmData[i].NameWithout_));
           }
      }

      return ListOfCreatedObjectsOfControls;
}


string RemoveAnyDigitsInString(string Value)
{
    for (short i = 0; i < Value.Length; i++)
    {
        if (char.IsDigit(Value[i]))
        {
            Value = Value.Replace(Value[i].ToString(), "");
        }
    }
    
    return Value;
}


public string NameSpace { get; set; } = "";
public bool IsInput { get; set; }
public bool IsView { get; set; }

// لو هذا المتغير بيساوي false معناها ان هيتم انشاء user control
public bool IsForm { get; set; }

public string TableSingleName { get; set; } = "";

string _TableName = "";
public string TableName
{
    get
    {
        return _TableName;
    }
    set
    {
        _TableName = value;

        _TableName = _TableName.Replace("_", "");
    }
}

private List<string> ListOfInitializedControls = new List<string>();
private List<string> ListOfCreatedObjectsOfControls = new List<string>();
private List<string> ListOfInitializedProperties = new List<string>();
private List<string> ListOfControlNames = new List<string>();

private List<clsColumnDataUILayer> _ListOfColunmData { get; set; }
public List<clsColumnDataUILayer> ListOfColunmData 
{
     get
     {
          if (_ListOfColunmData == null)
          {
               return new List<clsColumnDataUILayer>();
          }
          else
          {
               return _ListOfColunmData;
          }
     }
     set
     {
          _ListOfColunmData = value;

          if (_ListOfColunmData != null)
          {
                ListOfInitializedControls = GetListOfInitializedControls();
                ListOfCreatedObjectsOfControls = GetListOfCreatedObjectsOfControls();
                ListOfInitializedProperties = GetListOfInitializedProperties();
                ListOfControlNames = GetListOfControlNames();
          }
     }
}


